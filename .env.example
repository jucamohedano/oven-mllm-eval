# Cluster-specific environment variables.
# Copy this file to .env and fill in your values:
#     cp .env.example .env

# HuggingFace cache path (scratch/workspace on the cluster)
HF_HOME=/leonardo_scratch/fast/<YOUR_ACCOUNT>/.cache/huggingface

# Offline mode — compute nodes have no internet egress
HF_HUB_OFFLINE=1
WANDB_MODE=offline

# vLLM RPC timeout (seconds).  Increase if you see EngineDeadError
# on large models or when CUDA graph recapture takes longer than usual.
VLLM_EXECUTE_MODEL_TIMEOUT_SECONDS=1800
